{
    "info": {
        "_postman_id": "foogu-cms-api-001",
        "name": "Foogu CMS API",
        "description": "Laravel CMS API with Sanctum Authentication, UUID Primary Keys, and Posts CRUD",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Auto-save token to environment",
                                    "if (pm.response.code === 201) {",
                                    "    var jsonData = pm.response.json();",
                                    "    if (jsonData.token) {",
                                    "        pm.environment.set(\"auth_token\", jsonData.token);",
                                    "        console.log(\"Token saved: \" + jsonData.token);",
                                    "    }",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/register",
                            "host": ["{{base_url}}"],
                            "path": ["api", "register"]
                        },
                        "description": "Register a new user. Token will be automatically saved to environment."
                    },
                    "response": []
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Auto-save token to environment",
                                    "if (pm.response.code === 200) {",
                                    "    var jsonData = pm.response.json();",
                                    "    if (jsonData.token) {",
                                    "        pm.environment.set(\"auth_token\", jsonData.token);",
                                    "        console.log(\"Token saved: \" + jsonData.token);",
                                    "    }",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\",\n    \"device_name\": \"postman\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/login",
                            "host": ["{{base_url}}"],
                            "path": ["api", "login"]
                        },
                        "description": "Login with existing user credentials. Token will be automatically saved to environment."
                    },
                    "response": []
                },
                {
                    "name": "Logout",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{auth_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/logout",
                            "host": ["{{base_url}}"],
                            "path": ["api", "logout"]
                        },
                        "description": "Logout and revoke current token. Requires authentication."
                    },
                    "response": []
                },
                {
                    "name": "Get Current User (Me)",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{auth_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/me",
                            "host": ["{{base_url}}"],
                            "path": ["api", "me"]
                        },
                        "description": "Get current authenticated user information. Requires authentication."
                    },
                    "response": []
                }
            ],
            "description": "Authentication endpoints using Laravel Sanctum"
        },
        {
            "name": "Posts",
            "item": [
                {
                    "name": "Get All Posts",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/posts?per_page=10&page=1&sort_by=created_at&order=desc",
                            "host": ["{{base_url}}"],
                            "path": ["api", "posts"],
                            "query": [
                                {
                                    "key": "per_page",
                                    "value": "10",
                                    "description": "Items per page (default: 10)"
                                },
                                {
                                    "key": "page",
                                    "value": "1",
                                    "description": "Page number (default: 1)"
                                },
                                {
                                    "key": "sort_by",
                                    "value": "created_at",
                                    "description": "Sort field: id, title, slug, created_at, updated_at"
                                },
                                {
                                    "key": "order",
                                    "value": "desc",
                                    "description": "Sort order: asc, desc"
                                },
                                {
                                    "key": "author_id",
                                    "value": "",
                                    "description": "Filter by author UUID",
                                    "disabled": true
                                },
                                {
                                    "key": "search",
                                    "value": "",
                                    "description": "Search in title or body",
                                    "disabled": true
                                },
                                {
                                    "key": "slug",
                                    "value": "",
                                    "description": "Filter by specific slug",
                                    "disabled": true
                                }
                            ]
                        },
                        "description": "Get all posts with pagination, filtering, and sorting. Public endpoint."
                    },
                    "response": []
                },
                {
                    "name": "Get Single Post by Slug",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/posts/{{post_slug}}",
                            "host": ["{{base_url}}"],
                            "path": ["api", "posts", "{{post_slug}}"]
                        },
                        "description": "Get a single post by slug. Public endpoint."
                    },
                    "response": []
                },
                {
                    "name": "Create Post",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Auto-save post slug for testing",
                                    "if (pm.response.code === 201) {",
                                    "    var jsonData = pm.response.json();",
                                    "    if (jsonData.post && jsonData.post.slug) {",
                                    "        pm.environment.set(\"post_slug\", jsonData.post.slug);",
                                    "        console.log(\"Post slug saved: \" + jsonData.post.slug);",
                                    "    }",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{auth_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"My First Blog Post\",\n    \"body\": \"This is the content of my first blog post. It contains valuable information about Laravel and API development.\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/posts",
                            "host": ["{{base_url}}"],
                            "path": ["api", "posts"]
                        },
                        "description": "Create a new post. Slug will be auto-generated from title. Requires authentication."
                    },
                    "response": []
                },
                {
                    "name": "Create Post with Custom Slug",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{auth_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"My Custom Post\",\n    \"slug\": \"my-awesome-custom-slug\",\n    \"body\": \"This post has a custom slug instead of auto-generated one.\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/posts",
                            "host": ["{{base_url}}"],
                            "path": ["api", "posts"]
                        },
                        "description": "Create a new post with custom slug. Requires authentication."
                    },
                    "response": []
                },
                {
                    "name": "Update Post (PUT)",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{auth_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Updated Post Title\",\n    \"body\": \"This is the updated content of the blog post.\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/posts/{{post_slug}}",
                            "host": ["{{base_url}}"],
                            "path": ["api", "posts", "{{post_slug}}"]
                        },
                        "description": "Update an existing post (full update). Only post author can update. Requires authentication."
                    },
                    "response": []
                },
                {
                    "name": "Update Post (PATCH)",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{auth_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Only Title Updated\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/posts/{{post_slug}}",
                            "host": ["{{base_url}}"],
                            "path": ["api", "posts", "{{post_slug}}"]
                        },
                        "description": "Partial update of post. Only post author can update. Requires authentication."
                    },
                    "response": []
                },
                {
                    "name": "Delete Post",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{auth_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/posts/{{post_slug}}",
                            "host": ["{{base_url}}"],
                            "path": ["api", "posts", "{{post_slug}}"]
                        },
                        "description": "Delete a post. Only post author can delete. Requires authentication."
                    },
                    "response": []
                },
                {
                    "name": "Search Posts",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/posts?search=Laravel&per_page=20",
                            "host": ["{{base_url}}"],
                            "path": ["api", "posts"],
                            "query": [
                                {
                                    "key": "search",
                                    "value": "Laravel",
                                    "description": "Search keyword"
                                },
                                {
                                    "key": "per_page",
                                    "value": "20"
                                }
                            ]
                        },
                        "description": "Search posts by keyword in title or body. Public endpoint."
                    },
                    "response": []
                },
                {
                    "name": "Filter Posts by Author",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/posts?author_id={{author_id}}",
                            "host": ["{{base_url}}"],
                            "path": ["api", "posts"],
                            "query": [
                                {
                                    "key": "author_id",
                                    "value": "{{author_id}}",
                                    "description": "Author UUID"
                                }
                            ]
                        },
                        "description": "Filter posts by specific author. Public endpoint."
                    },
                    "response": []
                },
                {
                    "name": "Sort Posts by Title",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/posts?sort_by=title&order=asc",
                            "host": ["{{base_url}}"],
                            "path": ["api", "posts"],
                            "query": [
                                {
                                    "key": "sort_by",
                                    "value": "title"
                                },
                                {
                                    "key": "order",
                                    "value": "asc"
                                }
                            ]
                        },
                        "description": "Get posts sorted by title ascending. Public endpoint."
                    },
                    "response": []
                }
            ],
            "description": "Posts CRUD operations with slug-based routing"
        }
    ],
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [""]
            }
        },
        {
            "listen": "test",
            "script": {
                "type": "text/javascript",
                "exec": [""]
            }
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000",
            "type": "string"
        }
    ]
}
